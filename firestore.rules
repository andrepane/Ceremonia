rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() {
      return request.auth != null;
    }

    function inEvent(eventId) {
      return eventId is string && eventId.size() > 0;
    }

    match /events/{eventId} {
      allow read: if inEvent(eventId);

      match /config/{docId} {
        allow read: if true;
        allow write: if isAuth() && docId == 'main';
      }

      match /guests/{guestId} {
        allow read: if true;
        allow create, update: if isAuth()
          && request.resource.data.id == guestId
          && request.resource.data.updatedByUid == request.auth.uid;
        allow delete: if false;
      }

      match /activity/{activityId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.type in ['upload_photo', 'delete_photo', 'react_photo', 'write_dedication']
          && request.resource.data.guestId is string
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if isAuth()
          && request.resource.data.type in ['upload_photo', 'delete_photo', 'react_photo', 'write_dedication']
          && request.resource.data.guestId is string
          && resource.data.createdByUid == request.auth.uid
          && request.resource.data.createdByUid == resource.data.createdByUid;
        allow delete: if isAuth() && resource.data.createdByUid == request.auth.uid;
      }


      match /guestbookEntries/{guestId} {
        allow read: if true;
        allow create, update: if isAuth()
          && request.resource.data.id == guestId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.author is string
          && request.resource.data.content is string
          && request.resource.data.timestamp is int;
        allow delete: if false;
      }


      match /coupleGuestbook/{entryId} {
        allow read: if true;
        allow create, update: if isAuth()
          && request.resource.data.fromGuestId == entryId
          && request.resource.data.fromGuestId is string
          && request.resource.data.fromName is string
          && request.resource.data.content is string
          && request.resource.data.timestamp is int
          && request.resource.data.forCouple == true
          && request.resource.data.createdByUid == request.auth.uid;
        allow delete: if false;
      }

      match /photos/{photoId} {
        allow read: if true;
        allow create: if isAuth()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.authorGuestId is string
          && request.resource.data.storagePath is string
          && request.resource.data.uploadState in ['uploading', 'ready']
          && (
            !request.resource.data.keys().hasAny(['downloadURL'])
            || request.resource.data.downloadURL is string
          )
          && (
            !request.resource.data.keys().hasAny(['thumbnailURL'])
            || request.resource.data.thumbnailURL is string
          )
          && (
            !request.resource.data.keys().hasAny(['thumbnailPath'])
            || request.resource.data.thumbnailPath is string
          )
          && (
            !request.resource.data.keys().hasAny(['uploadId'])
            || request.resource.data.uploadId is string
          )
          && (
            !request.resource.data.keys().hasAny(['uploadPhase'])
            || request.resource.data.uploadPhase is string
          )
          && request.resource.data.likesCount == 0;
        allow update: if isAuth() && (
            (
              resource.data.authorUid == request.auth.uid
              && request.resource.data.authorUid == request.auth.uid
              && request.resource.data.authorGuestId == resource.data.authorGuestId
              && request.resource.data.storagePath == resource.data.storagePath
              && (
                !request.resource.data.keys().hasAny(['thumbnailPath'])
                || request.resource.data.thumbnailPath is string
                || request.resource.data.thumbnailPath == null
              )
              && (
                !request.resource.data.keys().hasAny(['downloadURL'])
                || request.resource.data.downloadURL is string
              )
              && (
                !request.resource.data.keys().hasAny(['thumbnailURL'])
                || request.resource.data.thumbnailURL is string
              )
              && request.resource.data.uploadState in ['uploading', 'ready']
            )
            ||
            (
              request.resource.data.diff(resource.data).changedKeys().hasOnly(['likesCount', 'likedByGuestIds'])
              && request.resource.data.likesCount is int
              && request.resource.data.likesCount >= 0
              && request.resource.data.likesCount <= resource.data.likesCount + 1
              && request.resource.data.likesCount >= resource.data.likesCount - 1
              && (
                !request.resource.data.keys().hasAny(['likedByGuestIds'])
                || request.resource.data.likedByGuestIds is list
              )
            )
          );
        // WARNING: delete is based on guestId (frontend-controlled).
        // This is less secure than UID-based validation but acceptable for private use (e.g., wedding app).
        allow delete: if isAuth() && resource.data.authorGuestId is string;

        match /likes/{likeId} {
          allow read: if true;
          allow create: if isAuth()
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.guestId is string
            && (
              likeId == request.auth.uid
              || likeId == request.resource.data.guestId
            );
          allow update: if false;
          allow delete: if isAuth() && resource.data.uid == request.auth.uid;
        }
      }

    }
  }
}
